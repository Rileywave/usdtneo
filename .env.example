# ============================================================
# USDT NEO - Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# --- Supabase PostgreSQL (REQUIRED) ---
# 1. Go to https://supabase.com and create a project (free tier)
# 2. Go to Project Settings > Database
# 3. Copy the "Connection string" under "URI" (it starts with postgresql://)
# 4. Make sure it includes the password: postgresql://postgres:[password]@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.xxxxxxxx.supabase.co:5432/postgres

# --- App Secret (REQUIRED - any random string) ---
APP_SECRET=change-this-to-a-random-string-at-least-32-characters-long

# --- Kimi OAuth (optional - for social login) ---
APP_ID=your-app-id
APP_SECRET=your-app-secret
VITE_APP_ID=your-app-id
VITE_KIMI_AUTH_URL=https://auth.kimi.com
KIMI_AUTH_URL=https://auth.kimi.com
KIMI_OPEN_URL=https://open.kimi.com
OWNER_UNION_ID=your-owner-union-id
